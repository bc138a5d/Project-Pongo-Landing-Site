# Production environment template. Copy to .env.production and fill values.
# .env.production is git-ignored and lives only on the server.

# 32 random bytes, base64-encoded. Required for Server Actions encryption.
# Generate with: openssl rand -base64 32
# Embedded into the build output at build time — do NOT rotate between builds
# unless you redeploy all instances simultaneously (would break in-flight
# Server Action calls from old clients).
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Short git SHA of the deployed commit. Set automatically by scripts/deploy.sh;
# override only for local debugging. Embedded into the build for version-skew
# protection during rolling deploys.
DEPLOYMENT_VERSION=
